@model CommunityComplaints.Models.Comment
@{ ViewData["Title"]="Comment Details"; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card" style="max-width:560px;"><div class="cc-card-header">Comment</div>
    <div class="cc-field"><div class="cc-field-label">Complaint</div><div class="cc-field-value">#@Model.Complaint.ComplaintId</div></div>
    
    <div class="cc-field"><div class="cc-field-label">User</div><div class="cc-field-value">@Model.User.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Message</div><div class="cc-field-value">@Model.Message</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Type</div><div class="cc-field-value">@(Model.IsInternal ? "Internal (staff only)" : "Public")</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Date</div><div class="cc-field-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div></div>
    
    <div style="margin-top:1.25rem;"><a class="cc-btn-outline" asp-action="Index">Back</a></div>
</div>