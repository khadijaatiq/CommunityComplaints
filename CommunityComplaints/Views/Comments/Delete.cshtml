@model CommunityComplaints.Models.Comment
@{ ViewData["Title"]="Delete Comment"; ViewData["Narrow"]=true; }
<div class="cc-card">
    <div style="font-size:20px;font-weight:600;color:var(--crit);margin-bottom:.5rem;">Delete comment?</div>
    <div class="cc-field"><div class="cc-field-label">Complaint</div><div class="cc-field-value">#@Model.Complaint.ComplaintId</div></div>
    
    <div class="cc-field"><div class="cc-field-label">User</div><div class="cc-field-value">@Model.User.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Message</div><div class="cc-field-value">@Model.Message</div></div>
    
    <form asp-action="Delete" method="post" style="display:flex;gap:8px;margin-top:1.25rem;"><input type="hidden" asp-for="CommentId"/><button type="submit" class="cc-btn-danger" style="padding:9px 20px;font-size:14px;font-weight:500;">Yes, delete</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></form>
</div>