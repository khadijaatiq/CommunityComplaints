@model CommunityComplaints.Models.Comment
@{ ViewData["Title"]="New Comment"; ViewData["Narrow"]=true; }
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New comment</div>
<form asp-action="Create" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<div class="form-group"><label class="form-label">Complaint</label><select class="form-select" asp-for="ComplaintId" asp-items="ViewBag.ComplaintId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label">User</label><select class="form-select" asp-for="UserId" asp-items="ViewBag.UserId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label" asp-for="Message">Message *</label><textarea class="form-textarea form-control" asp-for="Message" rows="4" maxlength="1000"></textarea><span class="field-error" asp-validation-for="Message"></span></div>
<div style="margin-top:4px;display:flex;align-items:center;gap:8px;"><input type="checkbox" asp-for="IsInternal" style="width:16px;height:16px;"/><label class="form-label" style="margin:0;">Internal note (staff only)</label></div>
<div style="display:flex;gap:8px;margin-top:1rem;"><button type="submit" class="cc-btn-primary">Create</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }