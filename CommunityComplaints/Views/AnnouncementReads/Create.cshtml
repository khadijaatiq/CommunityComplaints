@model CommunityComplaints.Models.AnnouncementRead
@{ ViewData["Title"]="New Read Record"; ViewData["Narrow"]=true; }
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New read record</div>
<form asp-action="Create" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<div class="form-group"><label class="form-label">Announcement</label><select class="form-select" asp-for="AnnouncementId" asp-items="ViewBag.AnnouncementId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label">User</label><select class="form-select" asp-for="UserId" asp-items="ViewBag.UserId"><option value="">-- Select --</option></select></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Create</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }