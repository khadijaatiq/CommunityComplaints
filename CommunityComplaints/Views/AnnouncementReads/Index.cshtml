@model IEnumerable<CommunityComplaints.Models.AnnouncementRead>
@{ ViewData["Title"]="Announcement Reads"; }
<div class="cc-page-header"><div><div class="cc-page-title">Announcement Reads</div><div class="cc-page-sub">@Model.Count() record(s)</div></div></div>
<div class="cc-card" style="padding:0;overflow:hidden;">
<table class="cc-table">
    <thead><tr><th>Announcement</th><th>User</th><th>Read at</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var item in Model) {
        <tr>
            <td style="font-weight:500;">#@item.Announcement.AnnouncementId</td>
            <td style="color:var(--muted);">@item.User.FullName</td>
            <td style="color:var(--muted);font-size:13px;">@item.ReadAt.ToString("dd MMM yyyy, HH:mm")</td>
            <td style="white-space:nowrap;">
                <a class="cc-btn-outline" asp-action="Details" asp-route-id="@item.Id">Details</a>
                <a class="cc-btn-danger" style="margin-left:6px;" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
        }
    </tbody>
</table></div>