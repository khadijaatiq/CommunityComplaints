@model CommunityComplaints.Models.AnnouncementRead
@{ ViewData["Title"]="Delete Read Record"; ViewData["Narrow"]=true; }
<div class="cc-card">
    <div style="font-size:20px;font-weight:600;color:var(--crit);margin-bottom:.5rem;">Delete read record?</div>
    <div class="cc-field"><div class="cc-field-label">Announcement</div><div class="cc-field-value">#@Model.Announcement.AnnouncementId</div></div>
    
    <div class="cc-field"><div class="cc-field-label">User</div><div class="cc-field-value">@Model.User.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Read at</div><div class="cc-field-value">@Model.ReadAt.ToString("dd MMM yyyy, HH:mm")</div></div>
    
    <form asp-action="Delete" method="post" style="display:flex;gap:8px;margin-top:1.25rem;"><input type="hidden" asp-for="Id"/><button type="submit" class="cc-btn-danger" style="padding:9px 20px;font-size:14px;font-weight:500;">Yes, delete</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></form>
</div>