@model CommunityComplaints.Models.Rating
@{ ViewData["Title"]="Edit Rating"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">Edit rating</div>
<form asp-action="Edit" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<input type="hidden" asp-for="RatingId"/>
<div class="form-group"><label class="form-label" asp-for="Stars">Stars</label>
<select class="form-select" asp-for="Stars">@for(int i=1;i<=5;i++){<option value="@i">@i ⭐</option>}</select></div>
<div class="form-group"><label class="form-label" asp-for="Feedback">Feedback</label><textarea class="form-textarea form-control" asp-for="Feedback" rows="4" maxlength="1000"></textarea></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Save</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }