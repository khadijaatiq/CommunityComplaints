@model CommunityComplaints.Models.Rating
@{ ViewData["Title"]="Rating Details"; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card" style="max-width:560px;"><div class="cc-card-header">Rating details</div>
    <div class="cc-field"><div class="cc-field-label">Complaint</div><div class="cc-field-value">#@Model.Complaint.ComplaintId</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Resident</div><div class="cc-field-value">@Model.Resident.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Stars</div><div class="cc-field-value">@string.Concat(Enumerable.Repeat("⭐", Model.Stars)) (@Model.Stars / 5)</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Feedback</div><div class="cc-field-value">@(string.IsNullOrEmpty(Model.Feedback) ? "—" : Model.Feedback)</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Submitted</div><div class="cc-field-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div></div>
    
    <div style="margin-top:1.25rem;display:flex;gap:8px;"><a class="cc-btn-outline" asp-action="Index">Back</a><a class="cc-btn-danger" asp-action="Delete" asp-route-id="@Model.RatingId">Delete</a></div>
</div>