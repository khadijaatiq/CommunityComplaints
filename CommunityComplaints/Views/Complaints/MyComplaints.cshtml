@model IEnumerable<CommunityComplaints.Models.Complaint>
@{ ViewData["Title"]="My Complaints"; }
@functions {
    string SBadge(string s) => s switch { "Open"=>"badge-open","InProgress"=>"badge-progress","Resolved"=>"badge-resolved","Cancelled"=>"badge-cancelled",_=>"badge-cancelled" };
    string UBadge(string u) => u switch { "Critical"=>"badge-critical","High"=>"badge-high","Medium"=>"badge-medium","Low"=>"badge-low",_=>"badge-low" };
    string SLabel(string s) => s == "InProgress" ? "In Progress" : s;
    string Initials(string n) { var p=n.Split(' ',System.StringSplitOptions.RemoveEmptyEntries); return p.Length>=2?$"{p[0][0]}{p[^1][0]}".ToUpper():n[..Math.Min(2,n.Length)].ToUpper(); }
}
<div class="cc-page-header">
    <div><div class="cc-page-title">My Complaints</div><div class="cc-page-sub">@Model.Count() complaint(s)</div></div>
    <a class="cc-btn-primary" asp-controller="Complaints" asp-action="Create">+ Submit complaint</a>
</div>
@if (!Model.Any()) {
<div class="cc-card" style="text-align:center;padding:3rem;color:var(--muted);"><div style="font-size:32px;margin-bottom:.5rem;">📋</div><div style="font-size:15px;font-weight:500;">No complaints yet</div><div style="font-size:13px;margin-top:4px;">Submit your first complaint using the button above.</div></div>
} else {
<div class="cc-card" style="padding:0;overflow:hidden;">
    <table class="cc-table">
        <thead><tr><th>Title</th><th>Category</th><th>Submitted</th><th>Status</th><th>Urgency</th><th>Actions</th></tr></thead>
        <tbody>
            @foreach (var item in Model) {
                var ratedList = ViewBag.RatedComplaints as List<int>;
                <tr>
                    <td style="font-weight:500;max-width:260px;">@item.Title</td>
                    <td style="color:var(--muted);">@item.Category</td>
                    <td style="color:var(--muted);white-space:nowrap;font-size:13px;">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                    <td><span class="badge @SBadge(item.Status)">@SLabel(item.Status)</span></td>
                    <td><span class="badge @UBadge(item.Urgency)">@item.Urgency</span></td>
                    <td style="white-space:nowrap;">
                        <a class="cc-btn-outline" asp-action="Details" asp-route-id="@item.ComplaintId">View</a>
                        @if (item.Status == "Open") {
                            <form asp-action="Cancel" asp-route-id="@item.ComplaintId" method="post" style="display:inline;margin-left:6px;" onsubmit="return confirm('Cancel this complaint?')"><button type="submit" class="cc-btn-danger">Cancel</button></form>
                        }
                        @if (item.Status == "Resolved" && (ratedList == null || !ratedList.Contains(item.ComplaintId))) {
                            <a class="cc-btn-outline" style="margin-left:6px;color:var(--res);border-color:var(--res);" href="/Ratings/Create?complaintId=@item.ComplaintId">⭐ Rate</a>
                        } else if (item.Status == "Resolved" && ratedList != null && ratedList.Contains(item.ComplaintId)) {
                            <span style="margin-left:8px;font-size:13px;color:var(--res);">✓ Rated</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
}
