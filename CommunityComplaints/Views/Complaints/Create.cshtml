@{
}
@model CommunityComplaints.Models.Complaint

<h2>Create Complaint</h2>

<form asp-action="Create" method="post">
    <input asp-for="Title" placeholder="Title" />
    <textarea asp-for="Description"></textarea>

    <select asp-for="Category" asp-items="ViewBag.Categories"></select>
    <select asp-for="DepartmentId" asp-items="ViewBag.DepartmentId"></select>

    <button type="submit">Submit</button>
</form>