@using Microsoft.AspNetCore.Http
@{ ViewData["Title"]="Home"; var userId=Context.Session.GetInt32("UserId"); var userName=Context.Session.GetString("UserName"); var roleId=Context.Session.GetInt32("RoleId"); }
@if (userId == null) {
<div style="text-align:center;padding:4rem 1rem 3rem;">
    <div style="font-size:13px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem;">Community Portal</div>
    <h1 style="font-size:36px;font-weight:600;line-height:1.2;margin-bottom:1rem;">Report issues.<br>Track resolutions.</h1>
    <p style="font-size:16px;color:var(--muted);max-width:420px;margin:0 auto 2rem;">A simple portal for residents to submit complaints and for staff to manage and resolve them.</p>
    <div style="display:flex;gap:12px;justify-content:center;">
        <a class="cc-btn-primary" asp-controller="Account" asp-action="Register">Get started</a>
        <a class="cc-btn-outline" asp-controller="Account" asp-action="Login">Sign in</a>
    </div>
</div>
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;max-width:700px;margin:0 auto;">
    <div class="cc-card" style="text-align:center;"><div style="font-size:24px;margin-bottom:.5rem;">📋</div><div style="font-weight:600;margin-bottom:.25rem;">Submit</div><div style="font-size:13px;color:var(--muted);">File a complaint in seconds</div></div>
    <div class="cc-card" style="text-align:center;"><div style="font-size:24px;margin-bottom:.5rem;">🔔</div><div style="font-weight:600;margin-bottom:.25rem;">Track</div><div style="font-size:13px;color:var(--muted);">Follow updates in real time</div></div>
    <div class="cc-card" style="text-align:center;"><div style="font-size:24px;margin-bottom:.5rem;">✅</div><div style="font-weight:600;margin-bottom:.25rem;">Resolve</div><div style="font-size:13px;color:var(--muted);">Rate outcomes once resolved</div></div>
</div>
} else if (roleId == 2) {
<div style="margin-bottom:1.5rem;"><div class="cc-page-title">Welcome, @userName</div><div style="font-size:14px;color:var(--muted);">Resident portal</div></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;max-width:500px;">
    <a class="cc-card" asp-controller="Complaints" asp-action="MyComplaints" style="text-decoration:none;display:block;transition:border-color .15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'"><div style="font-size:22px;margin-bottom:.5rem;">📋</div><div style="font-weight:500;">My Complaints</div><div style="font-size:13px;color:var(--muted);margin-top:3px;">View and track your submissions</div></a>
    <a class="cc-card" asp-controller="Complaints" asp-action="Create" style="text-decoration:none;display:block;transition:border-color .15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'"><div style="font-size:22px;margin-bottom:.5rem;">✏️</div><div style="font-weight:500;">Submit Complaint</div><div style="font-size:13px;color:var(--muted);margin-top:3px;">Report a new issue</div></a>
</div>
} else if (roleId == 1) {
<div style="margin-bottom:1.5rem;"><div class="cc-page-title">Staff Dashboard</div><div style="font-size:14px;color:var(--muted);">Welcome, @userName</div></div>
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;max-width:680px;">
    <a class="cc-card" asp-controller="Complaints" asp-action="Index" style="text-decoration:none;display:block;transition:border-color .15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'"><div style="font-size:22px;margin-bottom:.5rem;">📋</div><div style="font-weight:500;">All Complaints</div><div style="font-size:13px;color:var(--muted);margin-top:3px;">View and manage complaints</div></a>
    <a class="cc-card" asp-controller="Users" asp-action="Index" style="text-decoration:none;display:block;transition:border-color .15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'"><div style="font-size:22px;margin-bottom:.5rem;">👥</div><div style="font-weight:500;">Users</div><div style="font-size:13px;color:var(--muted);margin-top:3px;">Manage accounts</div></a>
    <a class="cc-card" asp-controller="Announcements" asp-action="Index" style="text-decoration:none;display:block;transition:border-color .15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'"><div style="font-size:22px;margin-bottom:.5rem;">📣</div><div style="font-weight:500;">Announcements</div><div style="font-size:13px;color:var(--muted);margin-top:3px;">Post community notices</div></a>
</div>
}
