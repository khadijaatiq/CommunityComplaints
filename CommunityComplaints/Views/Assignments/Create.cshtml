@model CommunityComplaints.Models.Assignment
@{ ViewData["Title"]="New Assignment"; ViewData["Narrow"]=true; }
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New assignment</div>
<form asp-action="Create" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<div class="form-group"><label class="form-label">Complaint</label><select class="form-select" asp-for="ComplaintId" asp-items="ViewBag.ComplaintId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label">Staff</label><select class="form-select" asp-for="StaffId" asp-items="ViewBag.StaffId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label">Assigned by</label><select class="form-select" asp-for="AssignedBy" asp-items="ViewBag.AssignedBy"><option value="">-- Select --</option></select></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Create</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }