@model IEnumerable<CommunityComplaints.Models.Assignment>
@{ ViewData["Title"]="Assignments"; }
<div class="cc-page-header"><div><div class="cc-page-title">Assignments</div><div class="cc-page-sub">@Model.Count() record(s)</div></div></div>
<div class="cc-card" style="padding:0;overflow:hidden;">
<table class="cc-table">
    <thead><tr><th>Complaint</th><th>Staff</th><th>Assigned by</th><th>Date</th><th>Active</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var item in Model) {
        <tr>
            <td style="font-family:var(--mono);font-size:13px;color:var(--muted);">#@item.Complaint.ComplaintId</td>
            <td style="font-weight:500;">@item.Staff.FullName</td>
            <td style="color:var(--muted);">@item.AssignedByNavigation.FullName</td>
            <td style="color:var(--muted);font-size:13px;white-space:nowrap;">@item.AssignedAt.ToString("dd MMM yyyy")</td>
            <td>@if(item.IsActive){<span class="badge badge-resolved">Yes</span>}else{<span class="badge badge-cancelled">No</span>}</td>
            <td style="white-space:nowrap;">
                <a class="cc-btn-outline" asp-action="Details" asp-route-id="@item.AssignmentId">Details</a>
                <a class="cc-btn-outline" style="margin-left:6px;" asp-action="Edit" asp-route-id="@item.AssignmentId">Edit</a>
                <a class="cc-btn-danger" style="margin-left:6px;" asp-action="Delete" asp-route-id="@item.AssignmentId">Delete</a>
            </td>
        </tr>
        }
    </tbody>
</table></div>