@model CommunityComplaints.Models.Assignment
@{ ViewData["Title"]="Delete Assignment"; ViewData["Narrow"]=true; }
<div class="cc-card">
    <div style="font-size:20px;font-weight:600;color:var(--crit);margin-bottom:.5rem;">Delete assignment?</div>
    <div class="cc-field"><div class="cc-field-label">Complaint</div><div class="cc-field-value">#@Model.Complaint.ComplaintId</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Staff</div><div class="cc-field-value">@Model.Staff.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Active</div><div class="cc-field-value">@(Model.IsActive ? "Yes" : "No")</div></div>
    
    <form asp-action="Delete" method="post" style="display:flex;gap:8px;margin-top:1.25rem;"><input type="hidden" asp-for="AssignmentId"/><button type="submit" class="cc-btn-danger" style="padding:9px 20px;font-size:14px;font-weight:500;">Yes, delete</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></form>
</div>