@model CommunityComplaints.Models.Role
@{ ViewData["Title"]="Role Details"; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card" style="max-width:520px;"><div class="cc-card-header">Role</div>
    <div class="cc-field"><div class="cc-field-label">Name</div><div class="cc-field-value">@Model.Name</div></div>
    
    <div style="margin-top:1.25rem;display:flex;gap:8px;"><a class="cc-btn-primary" asp-action="Edit" asp-route-id="@Model.RoleId">Edit</a><a class="cc-btn-outline" asp-action="Index">Back</a></div>
</div>