@model CommunityComplaints.Models.Role

@{ ViewData["Title"]="Delete"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card">
    <div style="font-size:20px;font-weight:600;color:var(--crit);margin-bottom:.5rem;">Delete role?</div>
    <div style="font-size:14px;color:var(--muted);margin-bottom:1.25rem;">This action cannot be undone.</div>
    <div class="cc-field"><div class="cc-field-label">Name</div><div class="cc-field-value">@Model.Name</div></div>
    
    <form asp-action="Delete" method="post" style="display:flex;gap:8px;margin-top:1.25rem;">
        <input type="hidden" asp-for="RoleId" />
        <button type="submit" class="cc-btn-danger" style="padding:9px 20px;font-size:14px;font-weight:500;">Yes, delete</button>
        <a class="cc-btn-outline" asp-action="Index">Cancel</a>
    </form>
</div>
