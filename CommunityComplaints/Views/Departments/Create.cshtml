@model CommunityComplaints.Models.Department
@{ ViewData["Title"]="New Department"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New department</div>
<form asp-action="Create" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<div class="form-group"><label class="form-label" asp-for="Name">Name *</label><input class="form-control" asp-for="Name" placeholder="e.g. Maintenance"/><span class="field-error" asp-validation-for="Name"></span></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Create</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }