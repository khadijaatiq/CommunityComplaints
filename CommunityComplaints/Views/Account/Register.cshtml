@model CommunityComplaints.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Create account"; ViewData["Narrow"] = true; }
<div class="cc-card">
    <div style="text-align:center;margin-bottom:1.5rem;">
        <div style="font-size:22px;font-weight:600;margin-bottom:4px;">Create account</div>
        <div style="font-size:14px;color:var(--muted);">Join the community portal</div>
    </div>
    <form asp-action="Register" method="post">
        <div asp-validation-summary="All" class="cc-alert cc-alert-error"></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group" style="margin:0">
                <label class="form-label" asp-for="Name">Full name</label>
                <input class="form-control" asp-for="Name" placeholder="Sara Ahmed" />
                <span class="field-error" asp-validation-for="Name"></span>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label" asp-for="UnitNumber">Unit number</label>
                <input class="form-control" asp-for="UnitNumber" placeholder="A-204 (optional)" />
            </div>
        </div>
        <div class="form-group" style="margin-top:12px;">
            <label class="form-label" asp-for="Email">Email address</label>
            <input class="form-control" asp-for="Email" placeholder="you@example.com" autocomplete="email" />
            <span class="field-error" asp-validation-for="Email"></span>
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="Phone">Phone <span style="font-weight:400;color:var(--muted)">(optional)</span></label>
            <input class="form-control" asp-for="Phone" placeholder="+92 300 0000000" />
        </div>
        <div class="form-group">
            <label class="form-label" asp-for="Role">Role</label>
            <select class="form-select" asp-for="Role">
                <option value="">-- Select role --</option>
                <option value="Resident">Resident</option>
                <option value="Staff">Staff</option>
            </select>
            <span class="field-error" asp-validation-for="Role"></span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="form-group" style="margin:0">
                <label class="form-label" asp-for="Password">Password</label>
                <input class="form-control" asp-for="Password" placeholder="Min 8 chars" autocomplete="new-password" />
                <span class="field-error" asp-validation-for="Password"></span>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label" asp-for="ConfirmPassword">Confirm password</label>
                <input class="form-control" asp-for="ConfirmPassword" placeholder="Match above" autocomplete="new-password" />
                <span class="field-error" asp-validation-for="ConfirmPassword"></span>
            </div>
        </div>
        <div style="font-size:12px;color:var(--muted);margin:.75rem 0;">Min 8 characters with uppercase, lowercase, digit, and special character.</div>
        <button type="submit" class="cc-btn-primary cc-btn-primary-wide">Create account</button>
    </form>
    <p style="text-align:center;font-size:13px;color:var(--muted);margin-top:1.25rem;">
        Already have an account? <a style="color:var(--accent);text-decoration:none;" asp-controller="Account" asp-action="Login">Sign in</a>
    </p>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
