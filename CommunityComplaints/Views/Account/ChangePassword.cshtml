@{
}
@model CommunityComplaints.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change password";
    ViewData["Narrow"] = true;
}

<div class="cc-card">

    <div style="text-align:center;margin-bottom:1.5rem;">

        <div style="font-size:22px;font-weight:600;margin-bottom:4px;">
            Change password
        </div>

        <div style="font-size:14px;color:var(--muted);">
            Create a secure new password
        </div>

    </div>

    <form asp-action="ChangePassword" method="post">

        <div asp-validation-summary="All"
             class="cc-alert cc-alert-error">
        </div>

        <input asp-for="Email" type="hidden" />

        <div style="display:grid;
            grid-template-columns:1fr 1fr;
            gap:12px;">

            <div class="form-group" style="margin:0">

                <label class="form-label"
                       asp-for="NewPassword">
                    New password
                </label>

                <input class="form-control"
                       asp-for="NewPassword"
                       placeholder="Min 8 chars"
                       autocomplete="new-password" />

                <span class="field-error"
                      asp-validation-for="NewPassword">
                </span>

            </div>

            <div class="form-group" style="margin:0">

                <label class="form-label"
                       asp-for="ConfirmNewPassword">
                    Confirm password
                </label>

                <input class="form-control"
                       asp-for="ConfirmNewPassword"
                       placeholder="Match above"
                       autocomplete="new-password" />

                <span class="field-error"
                      asp-validation-for="ConfirmNewPassword">
                </span>

            </div>

        </div>

        <div style="font-size:12px;
            color:var(--muted);
            margin:.75rem 0;">

            Min 8 characters with uppercase,
            lowercase, digit, and special character.

        </div>

        <button type="submit"
                class="cc-btn-primary cc-btn-primary-wide">
            Change Password
        </button>

    </form>

    <p style="text-align:center;
        font-size:13px;
        color:var(--muted);
        margin-top:1.25rem;">

        Back to

        <a style="color:var(--accent);
            text-decoration:none;"
               asp-action="Login">
            Sign in
        </a>

    </p>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}