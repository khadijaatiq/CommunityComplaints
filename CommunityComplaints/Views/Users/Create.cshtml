@model CommunityComplaints.Models.User
@{ ViewData["Title"]="New User"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New user</div>
<form asp-action="Create" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="FullName">Full name *</label><input class="form-control" asp-for="FullName"/></div>
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="UnitNumber">Unit number</label><input class="form-control" asp-for="UnitNumber" placeholder="Optional"/></div>
</div>
<div class="form-group" style="margin-top:12px;"><label class="form-label" asp-for="Email">Email *</label><input class="form-control" asp-for="Email" type="email"/></div>
<div class="form-group"><label class="form-label">Password *</label><input class="form-control" type="password" name="Password" placeholder="Min 8 characters" required minlength="8"/><span style="font-size:12px;color:var(--muted);">Requires uppercase, lowercase, digit, and special character.</span></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="Phone">Phone</label><input class="form-control" asp-for="Phone" placeholder="Optional"/></div>
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="RoleId">Role *</label><select class="form-select" asp-for="RoleId" asp-items="ViewBag.RoleId"><option value="">-- Select --</option></select></div>
</div>
<div style="display:flex;gap:8px;margin-top:1rem;"><button type="submit" class="cc-btn-primary">Create user</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }