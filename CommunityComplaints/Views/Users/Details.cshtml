@model CommunityComplaints.Models.User
@{ ViewData["Title"]="User Details"; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card" style="max-width:560px;"><div class="cc-card-header">User details</div>
    <div class="cc-field"><div class="cc-field-label">Full name</div><div class="cc-field-value">@Model.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Email</div><div class="cc-field-value">@Model.Email</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Role</div><div class="cc-field-value">@Model.Role?.Name</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Unit number</div><div class="cc-field-value">@(string.IsNullOrEmpty(Model.UnitNumber) ? "—" : Model.UnitNumber)</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Phone</div><div class="cc-field-value">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Status</div><div class="cc-field-value">@(Model.IsActive ? "Active" : "Inactive")</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Joined</div><div class="cc-field-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div></div>
    
    <div style="margin-top:1.25rem;display:flex;gap:8px;"><a class="cc-btn-primary" asp-action="Edit" asp-route-id="@Model.UserId">Edit</a><a class="cc-btn-outline" asp-action="Index">Back</a></div>
</div>