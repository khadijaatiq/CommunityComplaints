@model CommunityComplaints.Models.User
@{ ViewData["Title"]="Edit User"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">Edit user</div>
<form asp-action="Edit" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<input type="hidden" asp-for="UserId"/>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="FullName">Full name *</label><input class="form-control" asp-for="FullName"/></div>
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="UnitNumber">Unit number</label><input class="form-control" asp-for="UnitNumber" placeholder="Optional"/></div>
</div>
<div class="form-group" style="margin-top:12px;"><label class="form-label" asp-for="Email">Email *</label><input class="form-control" asp-for="Email" type="email"/></div>
<div class="form-group"><label class="form-label">New password</label><input class="form-control" type="password" name="NewPassword" placeholder="Leave blank to keep current" minlength="8"/><span style="font-size:12px;color:var(--muted);">Min 8 characters with uppercase, lowercase, digit, and special character.</span></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="Phone">Phone</label><input class="form-control" asp-for="Phone" placeholder="Optional"/></div>
    <div class="form-group" style="margin:0;"><label class="form-label" asp-for="RoleId">Role</label><select class="form-select" asp-for="RoleId" asp-items="ViewBag.RoleId"></select></div>
</div>
<div style="margin-top:12px;display:flex;align-items:center;gap:8px;"><input type="checkbox" asp-for="IsActive" style="width:16px;height:16px;"/><label class="form-label" style="margin:0;" asp-for="IsActive">Account active</label></div>
<div style="display:flex;gap:8px;margin-top:1rem;"><button type="submit" class="cc-btn-primary">Save changes</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }