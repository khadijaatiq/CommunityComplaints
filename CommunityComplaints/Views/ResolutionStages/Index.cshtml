@model IEnumerable<CommunityComplaints.Models.ResolutionStage>
@{ ViewData["Title"]="Resolution Stages"; }
<div class="cc-page-header"><div><div class="cc-page-title">Resolution Stages</div><div class="cc-page-sub">@Model.Count() stage(s)</div></div></div>
@if (!Model.Any()) {
<div class="cc-card" style="text-align:center;padding:3rem;color:var(--muted);"><div style="font-size:28px;margin-bottom:.5rem;">🔧</div><div style="font-weight:500;">No stages yet</div></div>
} else {
<div class="cc-card" style="padding:0;overflow:hidden;">
<table class="cc-table">
    <thead><tr><th>Title</th><th>Description</th><th>Complaint</th><th>Staff</th><th>Date</th><th>Actions</th></tr></thead>
    <tbody>
        @foreach (var item in Model) {
        <tr>
            <td style="font-weight:500;">@item.Title</td>
            <td style="color:var(--muted);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@item.Description</td>
            <td style="font-family:var(--mono);font-size:13px;color:var(--muted);">#@item.Complaint.ComplaintId</td>
            <td>@item.Staff.FullName</td>
            <td style="color:var(--muted);font-size:13px;white-space:nowrap;">@item.CreatedAt.ToString("dd MMM yyyy")</td>
            <td style="white-space:nowrap;">
                <a class="cc-btn-outline" asp-action="Details" asp-route-id="@item.StageId">Details</a>
                <a class="cc-btn-outline" style="margin-left:6px;" asp-action="Edit" asp-route-id="@item.StageId">Edit</a>
                <a class="cc-btn-danger" style="margin-left:6px;" asp-action="Delete" asp-route-id="@item.StageId">Delete</a>
            </td>
        </tr>
        }
    </tbody>
</table></div>}