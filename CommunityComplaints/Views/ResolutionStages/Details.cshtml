@model CommunityComplaints.Models.ResolutionStage
@{ ViewData["Title"]="Stage Details"; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card" style="max-width:560px;"><div class="cc-card-header">Resolution stage</div>
    <div class="cc-field"><div class="cc-field-label">Title</div><div class="cc-field-value">@Model.Title</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Description</div><div class="cc-field-value">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Complaint</div><div class="cc-field-value">#@Model.Complaint.ComplaintId</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Staff</div><div class="cc-field-value">@Model.Staff.FullName</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Created</div><div class="cc-field-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div></div>
    
    <div style="margin-top:1.25rem;display:flex;gap:8px;"><a class="cc-btn-primary" asp-action="Edit" asp-route-id="@Model.StageId">Edit</a><a class="cc-btn-outline" asp-action="Index">Back</a></div>
</div>