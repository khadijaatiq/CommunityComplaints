@model CommunityComplaints.Models.ResolutionStage
@{ ViewData["Title"]="New Stage"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New resolution stage</div>
<form asp-action="Create" method="post"><div asp-validation-summary="ModelOnly" class="cc-alert cc-alert-error"></div>
<div class="form-group"><label class="form-label">Complaint</label><select class="form-select" asp-for="ComplaintId" asp-items="ViewBag.ComplaintId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label">Staff member</label><select class="form-select" asp-for="StaffId" asp-items="ViewBag.StaffId"><option value="">-- Select --</option></select></div>
<div class="form-group"><label class="form-label" asp-for="Title">Title *</label><input class="form-control" asp-for="Title" placeholder="e.g. Inspected" maxlength="200"/><span class="field-error" asp-validation-for="Title"></span></div>
<div class="form-group"><label class="form-label" asp-for="Description">Description</label><textarea class="form-textarea form-control" asp-for="Description" rows="3" maxlength="500"></textarea></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Create</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }