@model CommunityComplaints.Models.Announcement
@{ ViewData["Title"]="Announcement Details"; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card" style="max-width:640px;"><div class="cc-card-header">Announcement</div>
    <div class="cc-field"><div class="cc-field-label">Title</div><div class="cc-field-value">@Model.Title</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Body</div><div class="cc-field-value">@Model.Body</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Expiry</div><div class="cc-field-value">@(Model.ExpiresAt.HasValue ? Model.ExpiresAt.Value.ToString("dd MMM yyyy, HH:mm") : "No expiry")</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Status</div><div class="cc-field-value">@(Model.IsActive ? "Active" : "Inactive")</div></div>
    
    <div class="cc-field"><div class="cc-field-label">Created</div><div class="cc-field-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div></div>
    
    <div style="margin-top:1.25rem;display:flex;gap:8px;"><a class="cc-btn-primary" asp-action="Edit" asp-route-id="@Model.AnnouncementId">Edit</a><a class="cc-btn-outline" asp-action="Index">Back</a></div>
</div>