@model CommunityComplaints.Models.Announcement
@{ ViewData["Title"] = "New Announcement"; ViewData["Narrow"] = true; }

<div style="margin-bottom:1rem;">
    <a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back to announcements</a>
</div>

<div class="cc-card">
    <div style="font-size:20px;font-weight:600;margin-bottom:.25rem;">New announcement</div>
    <div style="font-size:14px;color:var(--muted);margin-bottom:1.5rem;">This will be visible to all residents.</div>

    <form asp-action="Create" method="post">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="cc-alert cc-alert-error">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <div class="form-group">
            <label class="form-label" asp-for="Title">Title <span style="color:var(--crit)">*</span></label>
            <input class="form-control" asp-for="Title" placeholder="Min 5 characters" maxlength="200" />
            <span class="field-error" asp-validation-for="Title"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="Body">Body <span style="color:var(--crit)">*</span></label>
            <textarea class="form-textarea form-control" asp-for="Body" rows="5"
                      placeholder="Announcement content... (min 10 characters)" maxlength="2000"></textarea>
            <span class="field-error" asp-validation-for="Body"></span>
        </div>

        <div class="form-group">
            <label class="form-label" asp-for="ExpiresAt">
                Expiry date <span style="font-weight:400;color:var(--muted)">(optional)</span>
            </label>
            <input class="form-control" asp-for="ExpiresAt" type="datetime-local" />
            <span class="field-error" asp-validation-for="ExpiresAt"></span>
        </div>

        <div style="display:flex;gap:10px;margin-top:1.5rem;">
            <button type="submit" class="cc-btn-primary">Publish</button>
            <a class="cc-btn-outline" asp-action="Index">Cancel</a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
