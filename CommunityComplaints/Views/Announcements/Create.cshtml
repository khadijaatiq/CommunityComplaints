@model CommunityComplaints.Models.Announcement
@{ ViewData["Title"]="New Announcement"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">New announcement</div>
<form asp-action="Create" method="post">
<div class="form-group"><label class="form-label" asp-for="Title">Title *</label><input class="form-control" asp-for="Title" placeholder="Announcement title" maxlength="200"/></div>
<div class="form-group"><label class="form-label" asp-for="Body">Body *</label><textarea class="form-textarea form-control" asp-for="Body" rows="5" placeholder="Announcement content..." maxlength="2000"></textarea></div>
<div class="form-group"><label class="form-label" asp-for="ExpiresAt">Expiry date <span style="font-weight:400;color:var(--muted)">(optional)</span></label><input class="form-control" asp-for="ExpiresAt" type="datetime-local"/></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Publish</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>