@model CommunityComplaints.Models.Announcement
@{ ViewData["Title"]="Edit Announcement"; ViewData["Narrow"]=true; }
<div style="margin-bottom:1rem;"><a style="font-size:13px;color:var(--muted);text-decoration:none;" asp-action="Index">← Back</a></div>
<div class="cc-card"><div style="font-size:20px;font-weight:600;margin-bottom:1.25rem;">Edit announcement</div>
<form asp-action="Edit" method="post">
<input type="hidden" asp-for="AnnouncementId"/>
<div class="form-group"><label class="form-label" asp-for="Title">Title *</label><input class="form-control" asp-for="Title" maxlength="200"/></div>
<div class="form-group"><label class="form-label" asp-for="Body">Body *</label><textarea class="form-textarea form-control" asp-for="Body" rows="5" maxlength="2000"></textarea></div>
<div class="form-group"><label class="form-label" asp-for="ExpiresAt">Expiry date</label><input class="form-control" asp-for="ExpiresAt" type="datetime-local"/></div>
<div style="display:flex;gap:8px;"><button type="submit" class="cc-btn-primary">Save changes</button><a class="cc-btn-outline" asp-action="Index">Cancel</a></div>
</form></div>