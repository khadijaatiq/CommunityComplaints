@model IEnumerable<CommunityComplaints.Models.Announcement>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Announcements";
    var roleId     = Context.Session.GetInt32("RoleId") ?? 0;
    var readList   = ViewBag.ReadIds   as List<int>            ?? new List<int>();
    var readCounts = ViewBag.ReadCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="cc-page-header">
    <div>
        <div class="cc-page-title">Announcements</div>
        <div class="cc-page-sub">@Model.Count() announcement(s)</div>
    </div>
    @if (roleId == 1)
    {
        <a class="cc-btn-primary" asp-action="Create">+ New announcement</a>
    }
</div>

@if (!Model.Any())
{
    <div class="cc-card" style="text-align:center;padding:3rem;color:var(--muted);">
        <div style="font-size:28px;margin-bottom:.5rem;">📣</div>
        <div style="font-weight:500;">No announcements yet</div>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:.75rem;">
        @foreach (var item in Model)
        {
            var isActive = item.IsActive && (!item.ExpiresAt.HasValue || item.ExpiresAt > DateTime.Now);

            <div class="cc-card" style="@(!isActive ? "opacity:.6;" : "")">

                <!-- Title + badges -->
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;flex-wrap:wrap;margin-bottom:.5rem;">
                    <div style="font-size:16px;font-weight:600;">@item.Title</div>
                    <div style="display:flex;gap:8px;align-items:center;">
                        @if (isActive)
                        {
                            <span class="badge badge-resolved">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-cancelled">Inactive</span>
                        }
                        @if (item.ExpiresAt.HasValue)
                        {
                            <span style="font-size:12px;color:var(--muted);">
                                Expires @item.ExpiresAt.Value.ToString("dd MMM yyyy, HH:mm")
                            </span>
                        }
                    </div>
                </div>

                <!-- Body -->
                <div style="font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:.75rem;">
                    @item.Body
                </div>

                <!-- Footer row -->
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;padding-top:.75rem;border-top:1px solid var(--border);">
                    <div style="font-size:12px;color:var(--muted);">
                        Posted @item.CreatedAt.ToString("dd MMM yyyy")
                    </div>

                    <div style="display:flex;gap:8px;align-items:center;">

                        @* RESIDENT actions *@
                        @if (roleId == 2)
                        {
                            @if (readList.Contains(item.AnnouncementId))
                            {
                                <span style="font-size:13px;color:var(--res);">✓ Read</span>
                            }
                            else
                            {
                                <a class="cc-btn-outline" asp-action="MarkRead" asp-route-id="@item.AnnouncementId">
                                    Mark as read
                                </a>
                            }
                        }

                        @* STAFF actions *@
                        @if (roleId == 1)
                        {
                            <span style="font-size:13px;color:var(--muted);">
                                @(readCounts.ContainsKey(item.AnnouncementId) ? readCounts[item.AnnouncementId] : 0) read(s)
                            </span>

                            <a class="cc-btn-outline" asp-action="Edit" asp-route-id="@item.AnnouncementId">Edit</a>

                            @if (isActive)
                            {
                                <form asp-action="Deactivate" asp-route-id="@item.AnnouncementId"
                                      method="post" style="display:inline;"
                                      onsubmit="return confirm('Deactivate this announcement?')">
                                    <button type="submit" class="cc-btn-danger">Deactivate</button>
                                </form>
                            }
                        }

                    </div>
                </div>

            </div>
        }
    </div>
}
